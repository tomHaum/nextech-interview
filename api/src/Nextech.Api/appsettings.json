{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "HackerNews": {
    "BaseUrl": "https://hacker-news.firebaseio.com/v0/",
    "MaxStories": 500,
    "RefreshIntervalSeconds": 60,
    "ItemFetchConcurrency": 10
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  }
}
